{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$roomCode": {
        ".read": true,
        ".write": true,
        "mode": {
          ".validate": "newData.val() === 'quiz' || newData.val() === 'compliment' || newData.val() === 'mafia' || newData.val() === 'liar' || newData.val() === 'catchmind'"
        },
        "status": {
          ".validate": "newData.val() === 'waiting' || newData.val() === 'ready' || newData.val() === 'collecting' || newData.val() === 'playing' || newData.val() === 'result' || newData.val() === 'targetReveal' || newData.val() === 'authorGuess' || newData.val() === 'authorReveal' || newData.val() === 'roleAssigned' || newData.val() === 'roleReveal' || newData.val() === 'nightAction' || newData.val() === 'nightResult' || newData.val() === 'discussion' || newData.val() === 'voting' || newData.val() === 'voteResult' || newData.val() === 'roleRevealDead' || newData.val() === 'finished'"
        },
        "currentQuestionIndex": {
          ".validate": "newData.isNumber() && newData.val() >= -1"
        },
        "currentComplimentIndex": {
          ".validate": "newData.isNumber() && newData.val() >= -1"
        },
        "currentClueIndex": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 4"
        },
        "timeLimit": {
          ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 120"
        },
        "maxQuestionsPerStudent": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 10"
        },
        "maxComplimentsPerStudent": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 10"
        },
        "students": {
          "$studentId": {
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "score": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "connected": {
              ".validate": "newData.isBoolean()"
            }
          }
        },
        "questions": {
          "$questionId": {
            "authorName": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "authorKey": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60"
            },
            "question": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 160"
            },
            "choices": {
              ".validate": "newData.hasChildren(['0', '1', '2', '3'])",
              "$index": {
                ".validate": "$index.matches(/^[0-3]$/) && newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
              }
            },
            "correctIndex": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3"
            }
          }
        },
        "compliments": {
          "$complimentId": {
            "authorStudentId": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
            },
            "authorName": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "targetStudentId": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
            },
            "targetName": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "clues": {
              ".validate": "newData.hasChildren(['0', '1', '2', '3'])",
              "$index": {
                ".validate": "$index.matches(/^[0-4]$/) && newData.isString() && newData.val().length > 0 && newData.val().length <= 120"
              }
            }
          }
        },
        "liar": {
          "settings": {
            "wordA": {
              ".validate": "newData.isString() && newData.val().length <= 30"
            },
            "wordB": {
              ".validate": "newData.isString() && newData.val().length <= 30"
            },
            "liarCount": {
              ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 30"
            }
          },
          "assignments": {
            "$studentId": {
              "name": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
              },
              "word": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30"
              }
            }
          },
          "confirmations": {
            "$studentId": {
              "name": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
              },
              "confirmedAt": {
                ".validate": "newData.isNumber()"
              }
            }
          },
          "votes": {
            "$studentId": {
              "voterName": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
              },
              "targetStudentId": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
              },
              "targetName": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
              },
              "votedAt": {
                ".validate": "newData.isNumber()"
              }
            }
          },
          "majorityWord": {
            ".validate": "newData.isString() && newData.val().length <= 30"
          },
          "liarWord": {
            ".validate": "newData.isString() && newData.val().length <= 30"
          },
          "liarStudentIds": {
            "$index": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
            }
          },
          "startedAt": {
            ".validate": "!newData.exists() || newData.isNumber()"
          },
          "voteOpenedAt": {
            ".validate": "!newData.exists() || newData.isNumber()"
          },
          "voteResultOpenedAt": {
            ".validate": "!newData.exists() || newData.isNumber()"
          },
          "revealedAt": {
            ".validate": "!newData.exists() || newData.isNumber()"
          }
        },
        "answers": {
          "$questionId": {
            "$studentId": {
              "name": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
              },
              "selectedIndex": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3"
              },
              "isCorrect": {
                ".validate": "newData.isBoolean()"
              },
              "isSkipped": {
                ".validate": "newData.isBoolean()"
              },
              "responseTime": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 120"
              },
              "scoreEarned": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
              }
            }
          }
        }
      }
    }
  }
}
